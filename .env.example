# Local Development Environment Variables
# This file is NOT committed to Git (see .gitignore)

# Flask Secret Key (generate a new one for local dev)
FLASK_SECRET_KEY=your-local-dev-secret-key-change-this

# Email Configuration (Gmail)
# To get App Password: Google Account > Security > 2-Step Verification > App Passwords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=0xprogrammerx0@gmail.com
MAIL_PASSWORD=your-gmail-app-password-here
MAIL_DEFAULT_SENDER=0xprogrammerx0@gmail.com

# NOTE: When these are set, the app will try to send real emails.
# If you want to test without sending emails (just see in console),
# comment out the MAIL_ variables above by adding # at the start of each line.
